---
const clients = [
  "Constructora Andes",
  "Edificio Norte",
  "Retail Sur",
  "Comunidad Parque",
  "Hotel Cordillera",
];
---

<section class="border-y border-border bg-surface">
  <div class="container-x py-8">
    <p class="text-center text-xs font-semibold uppercase tracking-widest text-muted-foreground">
      Confian en nosotros administradoras, empresas y cientos de hogares
    </p>
    <div
      class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4"
    >
      {
        clients.map((c) => (
          <span class="text-base font-bold tracking-tight text-muted-foreground/70">
            {c}
          </span>
        ))
      }
    </div>
  </div>
</section>
