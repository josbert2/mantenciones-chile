---
import { Icon } from "astro-icon/components";
---

<style>
  .testimonial-section {
    width: 100%;
    max-width: 1680px;
    margin: 0 auto;
    padding: 170px 40px 105px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 20px;
  }

  .testimonial-header {
    width: 100%;
    text-align: right;
    margin-bottom: 40px;
  }

  .testimonial-title {
    font-family: "Inter", sans-serif;
    font-size: 98px;
    font-weight: 500;
    letter-spacing: -12px;
    line-height: 80%;
    color: #000000;
    margin: 0;
  }

  .testimonials-wrapper {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    width: 100%;
  }

  .testimonial-carousel {
    display: flex;
    gap: 10px;
    align-items: center;
    min-width: 290px;
  }

  .testimonial-card {
    width: 290px;
    background-color: #ffffff;
    border: 2px solid #cccccc;
    border-radius: 2px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .testimonial-image {
    width: 100%;
    height: 200px;
    background: linear-gradient(135deg, #8b0000 0%, #a41e35 100%);
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-size: 48px;
    position: relative;
    overflow: hidden;
  }

  .testimonial-quote {
    padding: 0 15px;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.6;
    color: #1D322D;
    margin: 0;
    min-height: 80px;
  }

  .testimonial-indicators {
    display: flex;
    gap: 8px;
    padding: 0 15px 15px;
    align-items: center;
  }

  .indicator {
    width: 24px;
    height: 4px;
    background-color: #cccccc;
    border-radius: 2px;
    transition: background-color 0.3s ease, width 0.3s ease;
  }

  .indicator.active {
    background-color: #8b0000;
    width: 32px;
  }

  .testimonial-content {
    flex: 1;
    max-width: 400px;
    background-color: #f3ac85;
    border-radius: 10px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .testimonial-description {
    font-family: "Inter", sans-serif;
    font-size: 17px;
    font-weight: 500;
    line-height: 140%;
    color: #1D322D;
    margin: 0;
  }

  .testimonial-cta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .btn-primary {
    background-color: #1F3630;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 12px 20px;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background-color: #0a1410;
    transform: translateY(-2px);
  }

  .btn-arrow {
    width: 48px;
    height: 48px;
    background-color: #ffffff;
    border: none;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-arrow:hover {
    background-color: #f0f0f0;
    transform: translateY(-2px);
  }

  .btn-arrow :global(svg) {
    width: 24px;
    height: 24px;
    color: #1D322D;
  }

  @media (max-width: 1199px) {
    .testimonial-section {
      padding: 80px 40px 105px;
    }

    .testimonial-title {
      font-size: 64px;
      letter-spacing: -8px;
    }
  }

  @media (max-width: 809px) {
    .testimonial-section {
      align-items: center;
      padding: 60px 12px 50px;
      gap: 82px;
    }

    .testimonial-header {
      text-align: center;
      width: 100%;
    }

    .testimonial-title {
      font-size: 42px;
      letter-spacing: -5px;
    }

    .testimonials-wrapper {
      flex-direction: column;
      align-items: stretch;
    }

    .testimonial-carousel {
      width: 100%;
      min-width: auto;
    }

    .testimonial-card {
      width: 100%;
    }

    .testimonial-content {
      max-width: unset;
      width: 100%;
    }

    .testimonial-cta {
      flex-direction: column-reverse;
    }

    .btn-primary {
      width: 100%;
      text-align: center;
    }

    .btn-arrow {
      width: 100%;
    }
  }
</style>

<section class="testimonial-section">
  <div class="testimonial-header">
    <h2 class="testimonial-title">Lo que nuestros clientes dicen</h2>
  </div>

  <div class="testimonials-wrapper">
    <div class="testimonial-carousel">
      <div class="testimonial-card">
        <div class="testimonial-image">
          <Icon name="hugeicons:star" />
        </div>
        <p class="testimonial-quote">
          "Servicio excelente, técnicos profesionales y certificados. Resolvieron el problema en una sola visita. Muy recomendado."
        </p>
        <div class="testimonial-indicators">
          <div class="indicator active"></div>
          <div class="indicator"></div>
          <div class="indicator"></div>
        </div>
      </div>
    </div>

    <div class="testimonial-content">
      <p class="testimonial-description">
        Más de Chile se especializa en servicios técnicos de calidad con garantía completa. Nuestros profesionales cuentan con certificaciones, equipamiento especializado y disponibilidad 24/7 para emergencias.
      </p>

      <div class="testimonial-cta">
        <button class="btn-primary">Conocer más</button>
        <button class="btn-arrow" aria-label="Ir a contacto">
          <Icon name="hugeicons:arrow-right-01" />
        </button>
      </div>
    </div>
  </div>
</section>
