---
const plans = [
  {
    name: "Visita puntual",
    price: "$24.900",
    period: "por visita",
    desc: "Para ese arreglo que necesitas resolver hoy.",
    features: [
      "Diagnóstico en terreno",
      "Cotización sin compromiso",
      "Garantía 90 días",
      "Atención en 24 hrs",
    ],
    cta: "Agendar visita",
    featured: false,
  },
  {
    name: "Plan Hogar",
    price: "$34.900",
    period: "por mes",
    desc: "Mantenimiento preventivo. Sin sorpresas.",
    features: [
      "2 visitas preventivas mensuales",
      "Prioridad en emergencias",
      "15% descuento en repuestos",
      "Reporte mensual",
      "Soporte WhatsApp",
    ],
    cta: "Contratar plan",
    featured: true,
  },
  {
    name: "Empresas y edificios",
    price: "A medida",
    period: "cotización",
    desc: "Para oficinas, locales y comunidades.",
    features: [
      "Técnico asignado",
      "Plan mantenimiento anual",
      "Facturación y OT",
      "Cobertura 24/7",
    ],
    cta: "Hablar con ventas",
    featured: false,
  },
];
---

<section id="precios" class="border-t border-border py-20 lg:py-28">
  <div class="container-x">
    <div class="mb-16" data-reveal>
      <h2 class="text-5xl font-display tracking-tight">Precios simples</h2>
      <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">Sin letra chica. Paga por lo que necesitas o contrata un plan.</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {
        plans.map((p) => (
          <article
            data-reveal
            class={`flex flex-col border-l-4 pl-6 py-4 ${
              p.featured ? "border-l-primary" : "border-l-primary/30"
            }`}
          >
            {p.featured && (
              <span class="mb-3 inline-flex w-fit text-xs font-bold text-primary uppercase">
                Más popular
              </span>
            )}
            <h3 class="text-lg font-bold text-foreground">{p.name}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{p.desc}</p>

            <div class="mt-6 mb-8 flex items-baseline gap-1.5">
              <span class="text-3xl font-bold text-foreground">{p.price}</span>
              <span class="text-sm text-muted-foreground">{p.period}</span>
            </div>

            <ul class="space-y-2 mb-8 flex-1">
              {p.features.map((f) => (
                <li class="text-sm text-muted-foreground">• {f}</li>
              ))}
            </ul>

            <a
              href="#cotizar"
              class={`px-4 py-2 text-center font-bold border text-sm transition ${
                p.featured
                  ? "bg-primary text-white border-primary hover:bg-primary/90"
                  : "border-primary text-primary hover:bg-primary/5"
              }`}
            >
              {p.cta}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
