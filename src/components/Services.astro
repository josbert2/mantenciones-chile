---
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Gasfiteria",
    desc: "Fugas, filtraciones, WC, calefont, cambio de llaves y destape de cañerias.",
    icon: "hugeicons:gas-pipe",
  },
  {
    title: "Electricidad",
    desc: "Cortocircuitos, tableros, enchufes, iluminacion y certificacion SEC.",
    icon: "hugeicons:flash",
  },
  {
    title: "Climatizacion",
    desc: "Instalacion, mantencion y limpieza de aire acondicionado split e inverter.",
    icon: "hugeicons:snow",
  },
  {
    title: "Emergencias 24/7",
    desc: "Reventones, inundaciones y fallas electricas urgentes cualquier dia.",
    icon: "hugeicons:24-hours-clock",
  },
];
---

<section id="servicios" class="py-20 lg:py-28">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-bold uppercase tracking-widest text-accent-strong"
        >Servicios</span
      >
      <h2
        class="mt-3 text-3xl font-display uppercase tracking-tight text-primary sm:text-4xl"
      >
        Todo lo que tu casa o edificio necesita, en un solo lugar
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Un solo equipo para resolver desde la gotera mas chica hasta la
        mantencion completa de tu propiedad.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        services.map((s) => (
          <article
            data-reveal
            class="group rounded-3xl border border-border bg-surface p-7 transition-all hover:-translate-y-1 hover:shadow-soft"
          >
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-primary/5 text-primary transition-colors group-hover:bg-accent group-hover:text-accent-foreground">
              <Icon name={s.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-5 text-xl font-bold text-primary">{s.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-muted-foreground">
              {s.desc}
            </p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong">
              Cotizar servicio
              <Icon name="hugeicons:arrow-right-01" class="h-4 w-4" />
            </span>
          </article>
        ))
      }
    </div>
  </div>
</section>
