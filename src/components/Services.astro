---
import { Icon } from "astro-icon/components";
import { servicios } from "../data/servicios";
---

<section id="servicios" class="py-20 lg:py-28">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-bold uppercase tracking-widest text-accent-strong"
        >Nuestros Servicios</span
      >
      <h2
        class="mt-3 text-3xl font-display uppercase tracking-tight text-primary sm:text-4xl"
      >
        8 especialidades en una sola empresa
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Desde hidrojet hasta pinturas corporativas. Equipamiento profesional
        y técnicos certificados para empresas, condominios y hogares en la RM.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        servicios.map((s) => (
          <a
            href={`/servicios/${s.slug}`}
            data-reveal
            class="group block rounded-3xl border border-border bg-surface p-7 transition-all hover:-translate-y-1 hover:shadow-soft"
          >
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-primary/5 text-primary transition-colors group-hover:bg-accent group-hover:text-accent-foreground">
              <Icon name={s.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-5 text-xl font-bold text-primary">{s.titulo}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-muted-foreground">
              {s.resumen}
            </p>
            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-strong">
              Ver servicio
              <Icon name="hugeicons:arrow-right-01" class="h-4 w-4" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
