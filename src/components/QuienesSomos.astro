<style>
  .about-section {
    width: 100%;
    padding: 120px 40px;
    background-color: #ffffff;
    display: flex;
    justify-content: center;
  }

  .about-container {
    max-width: 800px;
  }

  .about-label {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 24px 0;
  }

  .about-title {
    font-family: "Inter", sans-serif;
    font-size: 64px;
    font-weight: 700;
    line-height: 130%;
    letter-spacing: -1.5px;
    color: #000000;
    margin: 0 0 32px 0;
  }

  .about-accent {
    color: #8b0000;
  }

  .btn-learn-more {
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 2px;
    padding: 12px 28px;
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .btn-learn-more:hover {
    background-color: #8b0000;
  }

  @media (max-width: 809px) {
    .about-section {
      padding: 80px 20px;
    }

    .about-title {
      font-size: 42px;
      letter-spacing: -0.8px;
    }
  }
</style>

<section class="about-section">
  <div class="about-container">
    <p class="about-label">Quiénes somos</p>

    <h2 class="about-title">
      Desde nuestros inicios, Más de Chile ha proporcionado <span class="about-accent">servicios técnicos especializados</span> en hidrojet, gasfitería, cerrajería y emergencias 24/7.
    </h2>

    <a href="#cotizar" class="btn-learn-more">Learn more</a>
  </div>
</section>
