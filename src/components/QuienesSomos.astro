---
import { Icon } from "astro-icon/components";

const valores = [
  {
    icon: "hugeicons:justice-scale-01",
    title: "Conducta Ética",
    desc: "Actuamos bajo estrictos principios de integridad, honestidad y compromiso en cada entrega técnica.",
  },
  {
    icon: "hugeicons:security-check",
    title: "Seguridad & Calidad",
    desc: "Priorizamos la prevención y la calidad del trabajo, resguardando la infraestructura y las personas.",
  },
  {
    icon: "hugeicons:user-group",
    title: "Trabajo en Equipo",
    desc: "Sinergia de técnicos especializados enfocados en los objetivos de nuestros clientes de forma ágil.",
  },
];
---

<section id="nosotros" class="border-b border-border py-24 lg:py-32">
  <div class="container-x">
    <!-- Identidad -->
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div data-reveal>
        <p class="eyebrow flex items-center gap-2.5">
          <span class="h-px w-8 bg-primary"></span>
          Nuestra identidad
        </p>
        <p
          class="mt-6 font-mono text-sm uppercase tracking-[0.15em] text-muted-foreground"
        >
          Desde 2013 · Santiago, RM
        </p>
      </div>
      <h2
        class="font-display text-3xl font-extrabold uppercase leading-[1.02] tracking-[-0.02em] text-foreground sm:text-4xl lg:text-[2.9rem]"
        data-reveal
      >
        Construimos relaciones de confianza a largo plazo con una cultura
        orientada a la <span class="text-primary">excelencia operativa</span> y la
        seguridad.
      </h2>
    </div>

    <!-- Mision & Vision -->
    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:mt-20">
      <article
        class="border-l-2 border-primary bg-surface p-8 shadow-soft lg:p-10"
        data-reveal
      >
        <h3 class="font-display text-xl font-bold uppercase tracking-tight text-foreground">
          Nuestra Misión
        </h3>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          Entregar servicios y soluciones integrales de mantenimiento superando
          las expectativas de nuestros clientes, garantizando la máxima
          eficiencia y una conducta de total responsabilidad con la seguridad,
          la salud ocupacional y el medio ambiente.
        </p>
      </article>
      <article
        class="border-l-2 border-primary bg-surface p-8 shadow-soft lg:p-10"
        data-reveal
      >
        <h3 class="font-display text-xl font-bold uppercase tracking-tight text-foreground">
          Nuestra Visión
        </h3>
        <p class="mt-4 leading-relaxed text-muted-foreground">
          Consolidarnos como una empresa referente y líder en el mercado chileno
          de mantenimiento e infraestructura, implementando la mejora continua y
          anticipándonos a las dinámicas operativas de las mayores industrias
          del país.
        </p>
      </article>
    </div>

    <!-- Valores -->
    <div class="mt-16 lg:mt-20">
      <p class="eyebrow" data-reveal>Valores fundacionales</p>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          valores.map((v) => (
            <article
              class="group border-t-2 border-border bg-surface p-7 transition-colors hover:border-primary"
              data-reveal
            >
              <span class="grid h-12 w-12 place-items-center rounded-md bg-primary/10 text-primary">
                <Icon name={v.icon} class="h-6 w-6" />
              </span>
              <h3 class="mt-5 font-display text-lg font-bold text-foreground">
                {v.title}
              </h3>
              <p class="mt-2 text-[15px] leading-relaxed text-muted-foreground">
                {v.desc}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
