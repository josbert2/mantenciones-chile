<style>
  .about-section {
    width: 100%;
    padding: 100px 40px;
    background-color: #ffffff;
    display: flex;
    justify-content: center;
  }

  .about-container {
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .about-label {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
  }

  .about-title {
    font-family: "Inter", sans-serif;
    font-size: 72px;
    font-weight: 800;
    line-height: 120%;
    letter-spacing: -2px;
    color: #000000;
    margin: 0;
  }

  .about-accent {
    color: #8b0000;
    font-weight: 800;
  }

  .btn-learn-more {
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 14px 32px;
    font-family: "Inter", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    width: fit-content;
  }

  .btn-learn-more:hover {
    background-color: #8b0000;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 1199px) {
    .about-section {
      padding: 80px 40px;
    }

    .about-title {
      font-size: 56px;
      letter-spacing: -1.5px;
    }
  }

  @media (max-width: 809px) {
    .about-section {
      padding: 60px 20px;
    }

    .about-container {
      gap: 24px;
    }

    .about-title {
      font-size: 40px;
      letter-spacing: -1px;
    }

    .btn-learn-more {
      padding: 12px 28px;
      font-size: 12px;
    }
  }
</style>

<section class="about-section">
  <div class="about-container">
    <p class="about-label">Quiénes somos</p>

    <h2 class="about-title">
      Desde nuestros inicios, Más de Chile ha proporcionado <span class="about-accent">servicios técnicos especializados</span> en hidrojet, gasfitería, cerrajería, obras civiles y emergencias 24/7 en toda la Región Metropolitana.
    </h2>

    <a href="#cotizar" class="btn-learn-more">
      Conocer más
    </a>
  </div>
</section>
