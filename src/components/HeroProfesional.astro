---
import { Icon } from "astro-icon/components";
---

<style>
  .hero-section {
    background-color: #FFFEF2;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: 41px;
    width: 100%;
    min-height: 100vh;
    padding: 60px 40px;
    font-family: "Inter", sans-serif;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 41px;
    max-width: 900px;
  }

  .hero-text-group {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 24px;
  }

  .hero-title {
    font-size: 90px;
    font-weight: 500;
    line-height: 90px;
    letter-spacing: -5.4px;
    color: #1D322D;
    margin: 0;
    max-width: 700px;
    text-align: right;
  }

  .hero-description {
    font-size: 17px;
    color: #1D322D;
    text-align: right;
    line-height: 1.6;
    max-width: 400px;
    margin: 0;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: flex-end;
  }

  .btn-primary {
    background-color: #1F3630;
    color: #FDFCEE;
    border: none;
    border-radius: 10px;
    padding: 14px 28px;
    width: 144px;
    height: 48px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    font-family: "Inter", sans-serif;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary:hover {
    background-color: #0a1410;
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: #F3AC85;
    color: #1D322D;
    border: none;
    border-radius: 10px;
    width: 50px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background-color: #e89968;
    transform: translateY(-2px);
  }

  .btn-secondary :global(svg) {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 768px) {
    .hero-section {
      align-items: center;
      padding: 40px 20px;
    }

    .hero-content {
      align-items: center;
    }

    .hero-text-group {
      align-items: center;
    }

    .hero-title {
      font-size: 48px;
      line-height: 48px;
      text-align: center;
      max-width: 100%;
    }

    .hero-description {
      text-align: center;
      max-width: 100%;
    }

    .hero-buttons {
      justify-content: center;
    }
  }
</style>

<section class="hero-section">
  <div class="hero-content">
    <div class="hero-text-group">
      <h1 class="hero-title">Servicios técnicos de verdad</h1>
      <p class="hero-description">
        Soluciones profesionales en hidrojet, gasfitería, cerrajería y emergencias 24/7. Técnicos certificados, equipamiento especializado y garantía completa.
      </p>
    </div>

    <div class="hero-buttons">
      <button class="btn-primary">Cotizar ahora</button>
      <button class="btn-secondary" aria-label="Ir a WhatsApp">
        <Icon name="hugeicons:arrow-right-01" />
      </button>
    </div>
  </div>
</section>
