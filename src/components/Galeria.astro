---
import { Icon } from "astro-icon/components";

const cdn = (id: string) =>
  `https://framerusercontent.com/images/${id}.png?scale-down-to=512&width=2048&height=2048`;

const trabajos = [
  { img: "8FKXOumsLuAOf81tpPnI3zu2Jg", cat: "Hidrojet & Destapes", loc: "Supermercado · RM" },
  { img: "vzqNanbKCcj5CLe2o3o7dvcpY", cat: "Gasfitería", loc: "Local comercial · Santiago" },
  { img: "5AgeMShXPsGp8UgPgzzfhnQJ9c", cat: "Emergencia eléctrica", loc: "Retail · RM" },
  { img: "h8RHPQdFh0mQtKGjopKy3nIi2A", cat: "Limpieza de campanas", loc: "Gastronomía · Santiago" },
  { img: "qIjlcu2mcGbEtpBhazcWPQTkIU", cat: "Carpintería & Cerrajería", loc: "Bodega · RM" },
  { img: "ljcpAUhpHnqi1zhA3LtTu63Cy3U", cat: "Obras civiles", loc: "Estacionamiento · Santiago" },
];

// Duplicamos para que el loop sea continuo
const slides = [...trabajos, ...trabajos];
---

<section id="galeria" class="overflow-hidden py-24 lg:py-32">
  <!-- Encabezado -->
  <div class="container-x text-center">
    <div
      class="flex items-center justify-center gap-1 font-mono text-sm text-primary"
      data-reveal
    >
      <span>//</span>
      <span>Galería</span>
    </div>
    <h2
      class="mx-auto mt-4 max-w-2xl font-display text-3xl font-extrabold leading-[1.12] tracking-[-0.02em] text-foreground sm:text-4xl lg:text-[2.6rem]"
      data-reveal
    >
      Descubre el trabajo técnico<br class="hidden sm:block" /> detrás de cada
      operación.
    </h2>
  </div>

  <!-- Slideshow -->
  <div
    id="galeria-slider"
    class="mx-auto mt-10 w-full max-w-[76rem] px-5"
    data-reveal
  >
    <div class="slider-viewport overflow-hidden py-12">
      <div id="galeria-track" class="slider-track flex gap-6">
        {
          slides.map((t, i) => (
            <figure
              class="slide group relative aspect-[1080/1136] w-[260px] shrink-0 overflow-hidden rounded-xl bg-muted lg:w-[376px]"
              data-i={i}
            >
              <img
                src={cdn(t.img)}
                alt={`${t.cat} — Más de Chile`}
                width="376"
                height="395"
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
                draggable="false"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-foreground/85 via-foreground/15 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
              <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 translate-y-3 p-5 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
                <p class="font-mono text-[0.62rem] uppercase tracking-[0.16em] text-primary">
                  {t.loc}
                </p>
                <p class="mt-1 font-display text-lg font-bold text-white">
                  {t.cat}
                </p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>

    <!-- Controles -->
    <div class="mt-6 flex items-center justify-center gap-3">
      <button
        id="galeria-prev"
        aria-label="Anterior"
        class="grid h-11 w-11 place-items-center rounded-full border border-border bg-surface text-foreground transition-colors hover:border-primary hover:text-primary"
      >
        <Icon name="hugeicons:arrow-left-01" class="h-5 w-5" />
      </button>
      <button
        id="galeria-next"
        aria-label="Siguiente"
        class="grid h-11 w-11 place-items-center rounded-full border border-border bg-surface text-foreground transition-colors hover:border-primary hover:text-primary"
      >
        <Icon name="hugeicons:arrow-right-01" class="h-5 w-5" />
      </button>
    </div>
  </div>
</section>

<style>
  .slider-track {
    will-change: transform;
    transition: transform 0.75s cubic-bezier(0.65, 0, 0.35, 1);
  }
  /* Slides laterales: chicas. La del centro: grande */
  .slide {
    transform-origin: center;
    transform: scale(0.84);
    opacity: 0.6;
    transition:
      transform 0.75s cubic-bezier(0.65, 0, 0.35, 1),
      opacity 0.75s ease;
  }
  .slide.is-center {
    transform: scale(1.06);
    opacity: 1;
    z-index: 2;
  }
  @media (prefers-reduced-motion: reduce) {
    .slider-track,
    .slide {
      transition: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const root = document.getElementById("galeria-slider");
    const track = document.getElementById("galeria-track");
    if (!root || !track) return;

    const slides = Array.from(track.children);
    const LEN = slides.length / 2; // set original
    const EASE = "transform 0.75s cubic-bezier(0.65, 0, 0.35, 1)";
    let i = 0;
    let animating = false;

    const step = () => {
      // offsetWidth = ancho de layout (NO afectado por el scale de las slides)
      const w = slides[0].offsetWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap) || 24;
      return w + gap;
    };

    const paint = (animate) => {
      track.style.transition = animate ? EASE : "none";
      track.style.transform = "translate3d(" + -i * step() + "px,0,0)";
      // la del medio de las 3 visibles es i+1
      slides.forEach((s, idx) => s.classList.toggle("is-center", idx === i + 1));
    };

    const go = (dir) => {
      if (animating) return;
      animating = true;
      i += dir;

      if (i < 0) {
        // saltar al final sin animar y luego retroceder
        i = LEN;
        paint(false);
        void track.offsetHeight; // forzar reflow
        i = LEN - 1;
      }
      paint(true);

      window.setTimeout(() => {
        if (i >= LEN) {
          i = 0;
          paint(false);
        }
        animating = false;
      }, 780);
    };

    paint(false);
    window.addEventListener("resize", () => paint(false));

    document
      .getElementById("galeria-next")
      ?.addEventListener("click", () => go(1));
    document
      .getElementById("galeria-prev")
      ?.addEventListener("click", () => go(-1));

    // Autoplay: pasa de slide en slide, pausa al hover
    let timer = null;
    const start = () => {
      if (timer) return;
      timer = window.setInterval(() => go(1), 3200);
    };
    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = null;
    };
    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", start);

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) e.isIntersecting ? start() : stop();
    });
    io.observe(root);
  })();
</script>
