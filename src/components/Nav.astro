---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/#nosotros", label: "Nosotros" },
  { href: "/#servicios", label: "Servicios" },
  { href: "/#proceso", label: "Proceso" },
  { href: "/#testimonios", label: "Clientes" },
  { href: "/#faq", label: "Contacto" },
];
---

<header class="sticky top-4 z-50 px-4">
  <nav
    class="container-x flex h-16 items-center justify-between gap-4 rounded-full border border-border bg-surface/95 pl-4 pr-3 shadow-soft backdrop-blur-md"
  >
    <a href="/#inicio" class="flex items-center gap-2.5">
      <span
        class="grid h-9 w-9 place-items-center rounded-xl bg-primary text-accent"
      >
        <Icon name="hugeicons:wrench-01" class="h-5 w-5" />
      </span>
      <span class="font-display text-lg tracking-tight text-foreground">
        Mantenciones<span
          class="ml-1 rounded-md bg-accent px-1.5 py-0.5 text-accent-foreground"
          >CHILE</span
        >
      </span>
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-xs font-bold uppercase tracking-wide text-foreground/70 transition-colors hover:text-primary"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <a
        href="/#cotizar"
        class="rounded-full bg-primary px-5 py-2.5 text-xs font-bold uppercase tracking-wide text-primary-foreground transition-transform hover:-translate-y-0.5"
        >Cotizar</a
      >
      <button
        data-nav-toggle
        class="grid h-10 w-10 place-items-center rounded-full border border-border text-primary lg:hidden"
        aria-label="Abrir menu"
      >
        <Icon name="hugeicons:menu-01" class="h-5 w-5" />
      </button>
    </div>
  </nav>

  <div
    data-nav-menu
    class="container-x mt-2 hidden rounded-3xl border border-border bg-surface p-2 shadow-soft lg:hidden"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          class="block rounded-xl px-4 py-3 text-sm font-bold uppercase tracking-wide text-foreground hover:bg-muted"
        >
          {l.label}
        </a>
      ))
    }
  </div>
</header>
