---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";

const stats = [
  { n: "+25.000", l: "Objetivos logrados" },
  { n: "+15.000", l: "Soluciones ejecutadas" },
  { n: "+20", l: "Colaboradores" },
  { n: "+10", l: "Años de experiencia" },
];

const clientes = [
  "Jumbo",
  "Unimarc",
  "Santa Isabel",
  "Cencosud",
  "KFC",
  "Wendy's",
  "China Wok",
  "Spid",
];

const img =
  "https://framerusercontent.com/images/5AgeMShXPsGp8UgPgzzfhnQJ9c.png?scale-down-to=1024&width=2048&height=2048";
---

<section id="inicio" class="relative overflow-hidden bg-ink text-background">
  <div class="tech-grid pointer-events-none absolute inset-0 opacity-60"></div>
  <div
    class="pointer-events-none absolute -right-48 -top-40 h-[40rem] w-[40rem] rounded-full bg-primary/15 blur-[130px]"
  >
  </div>

  <div class="container-x relative pt-14 lg:pt-20">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12">
      <!-- Texto -->
      <div class="py-6 lg:py-10">
        <p class="eyebrow flex items-center gap-2.5 !text-primary">
          <span class="h-px w-8 bg-primary"></span>
          Ingeniería & mantenimiento multitécnico
        </p>

        <h1
          class="mt-6 font-display text-[2.6rem] font-extrabold uppercase leading-[0.92] tracking-[-0.02em] text-background sm:text-5xl lg:text-[4.1rem]"
        >
          Continuidad<br />operacional para<br />
          <span class="text-primary">tu infraestructura.</span>
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-relaxed text-background/65">
          Soluciones preventivas y correctivas de infraestructura comercial para
          retail, supermercados y gastronomía. Hidrojet, obras civiles,
          gasfitería y emergencias 24/7 en toda la Región Metropolitana.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a
            href="#cotizar"
            class="group inline-flex items-center gap-3 rounded-md bg-primary px-6 py-4 text-sm font-bold uppercase tracking-wide text-accent-foreground transition-colors hover:bg-accent-strong"
          >
            Solicitar servicio
            <Icon
              name="hugeicons:arrow-right-01"
              class="h-4 w-4 transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center rounded-md border border-white/20 px-6 py-4 text-sm font-bold uppercase tracking-wide text-background transition-colors hover:border-white/50"
          >
            Ver portfolio
          </a>
        </div>
      </div>

      <!-- Imagen -->
      <figure
        class="relative aspect-[5/6] overflow-hidden rounded-lg border border-white/10 sm:aspect-[16/10] lg:aspect-[4/5]"
      >
        <img
          src={img}
          alt="Técnico multitécnico de Más de Chile en terreno"
          width="1024"
          height="1024"
          class="h-full w-full object-cover grayscale"
          loading="eager"
        />
        <div class="pointer-events-none absolute inset-0 bg-ink/45"></div>
        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink via-ink/10 to-transparent"
        >
        </div>
        <figcaption
          class="absolute left-4 top-4 font-mono text-[0.68rem] uppercase tracking-[0.2em] text-background/85"
        >
          [ Operación en terreno ]
        </figcaption>
        <div class="absolute bottom-4 left-4 right-4">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.2em] text-primary">
            Santiago · Región Metropolitana
          </p>
          <p class="mt-1 font-display text-lg font-bold text-background">
            Cobertura corporativa nacional
          </p>
        </div>
      </figure>
    </div>
  </div>

  <!-- Barra de logros -->
  <div class="relative mt-10 border-t border-white/10 lg:mt-14">
    <div class="container-x grid grid-cols-2 lg:grid-cols-4">
      {
        stats.map((s, i) => (
          <div
            class:list={[
              "py-7 lg:py-9",
              i > 0 && "lg:border-l lg:border-white/10 lg:pl-8",
              i % 2 === 1 && "border-l border-white/10 pl-6 lg:pl-8",
              i >= 2 && "border-t border-white/10 lg:border-t-0",
            ]}
          >
            <div class="font-display text-3xl font-extrabold text-primary lg:text-[2.6rem]">
              {s.n}
            </div>
            <div class="mt-1.5 font-mono text-[0.68rem] uppercase tracking-[0.16em] text-background/55">
              {s.l}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Tira de clientes -->
  <div class="relative border-t border-white/10 bg-ink-soft/40">
    <div
      class="container-x flex flex-col gap-4 py-6 lg:flex-row lg:items-center lg:gap-10"
    >
      <span
        class="shrink-0 font-mono text-[0.66rem] uppercase tracking-[0.2em] text-background/45"
      >
        Confían en nosotros
      </span>
      <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
        {
          clientes.map((c) => (
            <span class="font-display text-base font-bold tracking-tight text-background/60">
              {c}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
