---
const casos = [
  {
    titulo: "Destape de cañería",
    servicio: "Hidrojet",
    resumen: "Línea de desagüe obstruida. Tecnología hidrojet sin ruptura. Sistema normalizado, 2 horas.",
  },
  {
    titulo: "Emergencia nocturna",
    servicio: "24/7",
    resumen: "Inundación a las 23:30. Respuesta en 38 minutos. Problema resuelto en 1.5 horas.",
  },
  {
    titulo: "Renovación de grifería",
    servicio: "Gasfitería",
    resumen: "Cambio de 12 grifos en piso completo. Artefactos sanitarios nuevos. Sistema moderno.",
  },
  {
    titulo: "Portón automático",
    servicio: "Cerrajería",
    resumen: "Instalación de sistema de apertura automática. Acceso 24/7. Control profesional.",
  },
  {
    titulo: "Limpieza de campanas",
    servicio: "Limpieza Industrial",
    resumen: "Sistema de extracción profundo. Cambio de motores y correas. Certificado.",
  },
  {
    titulo: "Pintura en altura",
    servicio: "Pinturas Corporativas",
    resumen: "Edificio de 8 pisos. Acabado profesional. Protocolos de seguridad. Fachada renovada.",
  },
];
---

<section id="casos" class="border-t border-border py-20 lg:py-28">
  <div class="container-x">
    <div class="mb-16" data-reveal>
      <h2 class="text-5xl font-display tracking-tight">Proyectos realizados</h2>
      <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">Emergencias, mantenimiento, remodelaciones.</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        casos.map((caso) => (
          <div data-reveal class="border-l-2 border-primary pl-6 py-2">
            <h3 class="font-bold text-foreground">{caso.titulo}</h3>
            <p class="text-sm text-primary font-semibold mt-1">{caso.servicio}</p>
            <p class="mt-4 text-sm leading-relaxed text-muted-foreground">{caso.resumen}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
