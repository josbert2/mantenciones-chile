---
const steps = [
  {
    n: "01",
    title: "Cuéntanos el problema",
    desc: "Escribes por WhatsApp o formulario. Describís qué pasa, podés enviar fotos.",
  },
  {
    n: "02",
    title: "Recibís cotización",
    desc: "Te enviamos valor claro. Agendamos la visita en el horario que vos elegís.",
  },
  {
    n: "03",
    title: "Vamos y lo resolvemos",
    desc: "El técnico llega puntual. Ejecuta el trabajo, te muestra todo funcionando.",
  },
  {
    n: "04",
    title: "Garantía de 90 días",
    desc: "Recibís boleta y respaldo. Si algo falla, volvemos sin costo adicional.",
  },
];
---

<section id="proceso" class="border-t border-border py-20 lg:py-28">
  <div class="container-x">
    <div class="mb-16" data-reveal>
      <h2 class="text-5xl font-display tracking-tight">Cómo trabajamos</h2>
      <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">Cuatro pasos. Sin complicaciones.</p>
    </div>

    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s) => (
          <div data-reveal class="border-l-2 border-primary pl-6">
            <div class="text-3xl font-bold text-primary/60">{s.n}</div>
            <h3 class="mt-4 text-lg font-bold text-foreground">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
