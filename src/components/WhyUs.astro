---
// Seccion "Nosotros" estilo blueprint (Handymandy): panel de titulo con
// textura de cruces, handles de seleccion y reveal palabra por palabra +
// parrafo, y panel de video abajo a la derecha con marco de cruces.
const heading =
  "Somos un equipo chileno de mantencion que ayuda a las personas a resolver los arreglos y mejoras de todos los dias.";
const words = heading.split(" ");
---

<section id="nosotros" class="py-20 lg:py-28">
  <div class="container-x">
    <div class="grid items-end gap-8 lg:grid-cols-2 lg:gap-0">
      <div class="blueprint bp-frame p-8 sm:p-10" data-reveal>
        <span class="handle handle-tl" aria-hidden="true"></span>
        <span class="handle handle-tr" aria-hidden="true"></span>
        <span class="handle handle-bl" aria-hidden="true"></span>
        <span class="handle handle-br" aria-hidden="true"></span>
        <h2
          class="reveal-words font-display text-2xl uppercase leading-[1.3] tracking-tight text-[#141414]/80 sm:text-3xl lg:text-[2.25rem]"
          data-reveal
        >
          {
            words.map((w, i) => (
              <>
                <span class="word" style={`--i:${i}`}>
                  {w}
                </span>
                {i < words.length - 1 ? " " : ""}
              </>
            ))
          }
        </h2>
      </div>

      <div class="px-2 pb-2 sm:px-8 sm:pb-8" data-reveal>
        <p class="text-base font-medium leading-relaxed tracking-[-0.01em] text-primary">
          Nuestro trabajo empezo como empiezan casi todos los buenos servicios
          locales: ayudando a amigos, vecinos y recomendados con trabajos
          chicos que no necesitaban una gran constructora, solo alguien
          confiable que llegara a la hora y lo hiciera bien. Con el tiempo, eso
          se convirtio en un servicio construido sobre una idea simple: que
          arreglar tu casa sea algo directo, no un dolor de cabeza.
        </p>
      </div>
    </div>

    <div class="bp-frame mt-8 grid lg:grid-cols-2" data-reveal>
      <span class="handle handle-tl" aria-hidden="true"></span>
      <span class="handle handle-tr" aria-hidden="true"></span>
      <span class="handle handle-bl" aria-hidden="true"></span>
      <span class="handle handle-br" aria-hidden="true"></span>
      <span class="handle handle-tm hidden lg:block" aria-hidden="true"></span>
      <span class="handle handle-bm hidden lg:block" aria-hidden="true"></span>
      <span class="bp-divider hidden lg:block" aria-hidden="true"></span>
      <div class="hidden lg:block"></div>
      <div class="blueprint p-7 sm:p-[30px]">
        <video
          src="https://videos.pexels.com/video-files/7480056/7480056-sd_960_506_25fps.mp4"
          poster="https://framerusercontent.com/images/KYL3j63NWHtNmSz545aVEicHZMI.png?width=2048&height=1080"
          class="aspect-[551/290] w-full rounded-[20px] object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
        ></video>
      </div>
    </div>
  </div>
</section>
