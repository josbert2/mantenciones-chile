---
import { Icon } from "astro-icon/components";
import { servicios } from "../data/servicios";
import { site } from "../data/site";

const social = [
  { icon: "hugeicons:facebook-01", href: site.sameAs[0] },
  { icon: "hugeicons:instagram", href: site.sameAs[1] },
  { icon: "hugeicons:new-twitter", href: "#" },
];

const cols = [
  {
    title: "Servicios",
    links: servicios.map((s) => ({
      label: s.titulo,
      href: `/servicios/${s.slug}`,
    })),
  },
  {
    title: "Empresa",
    links: [
      { label: "Nosotros", href: "/#nosotros" },
      { label: "Como trabajamos", href: "/#proceso" },
      { label: "Planes", href: "/#precios" },
      { label: "Clientes", href: "/#testimonios" },
    ],
  },
  {
    title: "Ayuda",
    links: [
      { label: "Preguntas frecuentes", href: "/#faq" },
      { label: "Cotizar", href: "/#cotizar" },
      { label: "Servicios", href: "/servicios" },
      { label: "Contacto", href: "/#cotizar" },
    ],
  },
];
const year = 2026;
---

<footer class="border-t border-border bg-surface">
  <div class="container-x py-16">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href="/#inicio" class="flex items-center gap-2.5">
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-primary text-accent">
            <Icon name="hugeicons:wrench-01" class="h-5 w-5" />
          </span>
          <span class="text-lg font-extrabold tracking-tight text-primary"
            >Mantenciones<span class="text-accent-strong">Chile</span></span
          >
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted-foreground">
          Servicio tecnico de mantencion para el hogar y empresas. Tecnicos
          certificados, precio claro y garantia en todo Chile.
        </p>
        <div class="mt-5 flex gap-3">
          {
            social.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" aria-label="Red social" class="grid h-9 w-9 place-items-center rounded-xl border border-border text-muted-foreground transition-colors hover:bg-primary hover:text-primary-foreground">
                <Icon name={s.icon} class="h-4 w-4" />
              </a>
            ))
          }
        </div>
      </div>

      {
        cols.map((c) => (
          <div>
            <h3 class="text-sm font-bold text-primary">{c.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {c.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-muted-foreground transition-colors hover:text-accent-strong">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-border pt-6 sm:flex-row"
    >
      <p class="text-sm text-muted-foreground">
        © {year} Mantenciones Chile. Todos los derechos reservados.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-sm text-muted-foreground hover:text-accent-strong">Terminos</a>
        <a href="#" class="text-sm text-muted-foreground hover:text-accent-strong">Privacidad</a>
      </div>
    </div>
  </div>
</footer>
