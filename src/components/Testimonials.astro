---
const reviews = [
  {
    quote:
      "Se me reventó una cañería un domingo y llegaron en menos de una hora. Rapidos, limpios y el precio fue el mismo que cotizaron.",
    name: "Carolina Rojas",
    role: "Providencia, Santiago",
  },
  {
    quote:
      "Administramos 3 edificios y ahora hacemos toda la mantencion con ellos. Responsables y siempre dejan registro de lo que hicieron.",
    name: "Marco Fuentes",
    role: "Administrador de comunidades",
  },
  {
    quote:
      "Instalaron el aire acondicionado y me explicaron todo. Se nota que saben. Los volvi a llamar para la mantencion.",
    name: "Daniela Perez",
    role: "Nunoa, Santiago",
  },
];
---

<section id="testimonios" class="py-20 lg:py-28">
  <div class="container-x">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="text-sm font-bold uppercase tracking-widest text-accent-strong"
        >Clientes</span
      >
      <h2
        class="mt-3 text-3xl font-display uppercase tracking-tight text-primary sm:text-4xl"
      >
        Lo que dicen quienes ya nos contrataron
      </h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        reviews.map((r) => (
          <figure
            data-reveal
            class="flex flex-col rounded-3xl border border-border bg-surface p-7"
          >
            <div class="flex gap-1 text-warning">
              {Array.from({ length: 5 }).map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="m12 2 3 6.9 7.5.6-5.7 4.9 1.8 7.3L12 17.8 5.4 21.7l1.8-7.3L1.5 9.5 9 8.9 12 2Z" />
                </svg>
              ))}
            </div>
            <blockquote class="mt-4 flex-1 text-[15px] leading-relaxed text-foreground">
              “{r.quote}”
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-3 border-t border-border pt-5">
              <span class="grid h-11 w-11 place-items-center rounded-full bg-primary text-sm font-bold text-primary-foreground">
                {r.name.split(" ").map((w) => w[0]).join("").slice(0, 2)}
              </span>
              <div>
                <p class="text-sm font-bold text-primary">{r.name}</p>
                <p class="text-xs text-muted-foreground">{r.role}</p>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
