---
const reviews = [
  {
    quote:
      "Se reventó una cañería un domingo y llegaron en menos de una hora. Rápidos, limpios y el precio fue el que cotizaron.",
    name: "Carolina Rojas",
    role: "Providencia",
  },
  {
    quote:
      "Administramos 3 edificios. Ahora hacemos toda la manutención con ellos. Responsables, siempre dejan registro de lo realizado.",
    name: "Marco Fuentes",
    role: "Administrador",
  },
  {
    quote:
      "Instalaron aire acondicionado y explicaron todo. Se nota que saben. Los volví a llamar para manutención.",
    name: "Daniela Pérez",
    role: "Ñuñoa",
  },
];
---

<section id="testimonios" class="border-t border-border py-20 lg:py-28">
  <div class="container-x">
    <div class="mb-16" data-reveal>
      <h2 class="text-5xl font-display tracking-tight">Clientes reales</h2>
      <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">Trabajos hechos, compromisos cumplidos.</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3">
      {
        reviews.map((r) => (
          <figure data-reveal class="flex flex-col border-l-2 border-primary pl-6 py-2">
            <blockquote class="flex-1 text-base leading-relaxed text-foreground">
              "{r.quote}"
            </blockquote>
            <figcaption class="mt-6 pt-4">
              <p class="font-bold text-foreground">{r.name}</p>
              <p class="text-sm text-muted-foreground">{r.role}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
