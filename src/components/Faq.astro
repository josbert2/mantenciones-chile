---
import { Icon } from "astro-icon/components";
import { faqPage } from "../lib/schema";

interface Props {
  faqs?: { q: string; a: string }[];
  eyebrow?: string;
  titulo?: string;
}

const defaultFaqs = [
  {
    q: "¿Atienden empresas y también particulares?",
    a: "Sí. Trabajamos con empresas, condominios, hoteles, restaurantes, colegios, clínicas y universidades, y también con hogares particulares. Al escribirnos puedes indicarnos desde dónde nos contactas para asignarte el equipo adecuado.",
  },
  {
    q: "¿En qué zonas trabajan?",
    a: "Cubrimos toda la Región Metropolitana, con cobertura corporativa a nivel nacional para clientes con operaciones en varias ciudades.",
  },
  {
    q: "¿Atienden emergencias fuera de horario?",
    a: "Sí. Contamos con servicio de emergencia 24/7 los 365 días del año para gasfitería, electricidad, cerrajería y camión de destape.",
  },
  {
    q: "¿La cotización tiene costo?",
    a: "No. Evaluamos el trabajo y te entregamos una cotización clara y sin compromiso antes de ejecutar cualquier servicio.",
  },
  {
    q: "¿Emiten factura y documentación para cumplimiento normativo?",
    a: "Sí. Emitimos factura para empresas y condominios, y entregamos certificado de disposición final en los servicios de hidrojet y gestión de riles.",
  },
  {
    q: "¿Qué experiencia tienen?",
    a: "Más de una década en el mercado chileno, con más de 15.000 soluciones técnicas ejecutadas para retail, supermercados y gastronomía.",
  },
];

const {
  faqs = defaultFaqs,
  eyebrow = "Preguntas frecuentes",
  titulo = "Resolvemos tus dudas",
} = Astro.props;
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(faqPage(faqs))}
/>


<section id="faq" class="border-t border-border py-20 lg:py-28">
  <div class="container-x grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
    <div data-reveal>
      <h2 class="text-5xl font-display tracking-tight">{titulo}</h2>
      <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
        Si no encuentras respuesta, escribenos por WhatsApp.
      </p>
      <a
        href="#cotizar"
        class="mt-6 inline-flex border border-primary bg-primary text-primary-foreground px-6 py-3 text-sm font-bold transition hover:bg-primary/90"
        >Escribir por WhatsApp</a
      >
    </div>

    <div class="space-y-4" data-reveal>
      {
        faqs.map((f, i) => (
          <div
            data-faq
            data-open={i === 0 ? "true" : "false"}
            class="group border-l-2 border-l-primary/20 pl-6 py-4 [&[data-open='true']]:border-l-primary"
          >
            <button
              data-faq-btn
              class="flex w-full items-start justify-between gap-4 text-left"
            >
              <span class="text-base font-bold text-foreground">{f.q}</span>
              <span class="text-primary font-bold shrink-0 group-[[data-open='true']]:rotate-45 transition">+</span>
            </button>
            <div class="grid grid-rows-[0fr] transition-all duration-300 group-[[data-open='true']]:grid-rows-[1fr]">
              <div class="overflow-hidden">
                <p class="pt-4 text-sm leading-relaxed text-muted-foreground">
                  {f.a}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
