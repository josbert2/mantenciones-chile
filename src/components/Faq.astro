---
import { Icon } from "astro-icon/components";
import { faqPage } from "../lib/schema";

interface Props {
  faqs?: { q: string; a: string }[];
  eyebrow?: string;
  titulo?: string;
}

const defaultFaqs = [
  {
    q: "En que comunas y ciudades atienden?",
    a: "Trabajamos en toda la Region Metropolitana y en las principales ciudades del pais. Escribenos tu direccion y te confirmamos disponibilidad al instante.",
  },
  {
    q: "Cuanto se demoran en llegar?",
    a: "Para servicios agendados coordinamos el horario que prefieras. En emergencias, nuestro tiempo promedio de respuesta es de 45 minutos.",
  },
  {
    q: "El presupuesto tiene costo?",
    a: "No. La cotizacion es gratis y sin compromiso. Solo pagas si apruebas el trabajo, y el valor final es el mismo que te informamos antes de empezar.",
  },
  {
    q: "Que incluye la garantia?",
    a: "Todos nuestros trabajos tienen 90 dias de garantia en mano de obra y materiales. Si el mismo problema reaparece, volvemos sin costo.",
  },
  {
    q: "Emiten boleta o factura?",
    a: "Si, entregamos boleta electronica en cada servicio y factura para empresas y comunidades que lo requieran.",
  },
];

const {
  faqs = defaultFaqs,
  eyebrow = "Preguntas frecuentes",
  titulo = "Resolvemos tus dudas antes de agendar",
} = Astro.props;
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(faqPage(faqs))}
/>


<section id="faq" class="border-t border-border py-20 lg:py-28">
  <div class="container-x grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
    <div data-reveal>
      <h2 class="text-5xl font-display tracking-tight">{titulo}</h2>
      <p class="mt-6 text-lg text-muted-foreground leading-relaxed">
        Si no encuentras respuesta, escribenos por WhatsApp.
      </p>
      <a
        href="#cotizar"
        class="mt-6 inline-flex border border-primary bg-primary text-primary-foreground px-6 py-3 text-sm font-bold transition hover:bg-primary/90"
        >Escribir por WhatsApp</a
      >
    </div>

    <div class="space-y-4" data-reveal>
      {
        faqs.map((f, i) => (
          <div
            data-faq
            data-open={i === 0 ? "true" : "false"}
            class="group border-l-2 border-l-primary/20 pl-6 py-4 [&[data-open='true']]:border-l-primary"
          >
            <button
              data-faq-btn
              class="flex w-full items-start justify-between gap-4 text-left"
            >
              <span class="text-base font-bold text-foreground">{f.q}</span>
              <span class="text-primary font-bold shrink-0 group-[[data-open='true']]:rotate-45 transition">+</span>
            </button>
            <div class="grid grid-rows-[0fr] transition-all duration-300 group-[[data-open='true']]:grid-rows-[1fr]">
              <div class="overflow-hidden">
                <p class="pt-4 text-sm leading-relaxed text-muted-foreground">
                  {f.a}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
