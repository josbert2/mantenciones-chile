---
import { Icon } from "astro-icon/components";

const bloques = [
  {
    icon: "hugeicons:clipboard",
    tag: "Preventivo",
    title: "Mantenimiento Preventivo",
    items: [
      "Limpieza técnica de campanas y ductos de extracción comercial",
      "Mantención de motores de extracción y ventiladores",
      "Soluciones integrales de gasfitería e instalaciones sanitarias",
      "Check List operacional de diagnóstico temprano de fallas",
    ],
  },
  {
    icon: "hugeicons:water-pump",
    tag: "Correctivo",
    title: "Saneamiento e Hidrojet",
    items: [
      "Camión hidrojet para destape de tuberías subterráneas y cámaras de grasa",
      "Lavado de alcantarillados con sistemas de alta presión",
      "Lavado de fachadas y letreros corporativos",
      "Mantención, limpieza y sellado integral de cubiertas",
    ],
  },
  {
    icon: "hugeicons:building-03",
    tag: "Obras civiles",
    title: "Infraestructura & Remodelaciones",
    items: [
      "Pintura epóxica, látex, óleo y de alto tráfico",
      "Reparación y pulido de pisos de trastienda y salas de venta",
      "Carpintería comercial, herrería, soldaduras y cerrajería",
      "Demarcación vial y reparación de estacionamientos",
      "Fabricación y montaje de cierres perimetrales, rejas y portones",
    ],
  },
];
---

<section id="portfolio" class="border-b border-border py-24 lg:py-32">
  <div class="container-x">
    <div class="max-w-2xl" data-reveal>
      <p class="eyebrow flex items-center gap-2.5">
        <span class="h-px w-8 bg-primary"></span>
        Portfolio de servicios
      </p>
      <h2
        class="mt-3 text-3xl font-semibold leading-[1.15] tracking-[-0.02em] text-foreground sm:text-4xl lg:text-[2.6rem]"
      >
        Soluciones preventivas y correctivas <em
          class="font-serif font-normal italic">integrales</em
        >
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
        Diseñadas para garantizar la continuidad operacional y preservar los
        activos de tu empresa, local o planta.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {
        bloques.map((b, i) => (
          <article
            class="flex flex-col border-t-2 border-ink bg-surface p-8 shadow-soft"
            data-reveal
          >
            <div class="flex items-center justify-between">
              <span class="grid h-12 w-12 place-items-center rounded-md bg-primary/10 text-primary">
                <Icon name={b.icon} class="h-6 w-6" />
              </span>
              <span class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-muted-foreground">
                {String(i + 1).padStart(2, "0")} · {b.tag}
              </span>
            </div>
            <h3 class="mt-6 text-xl font-semibold tracking-tight text-foreground">
              {b.title}
            </h3>
            <ul class="mt-5 space-y-3.5">
              {b.items.map((item) => (
                <li class="flex gap-3 text-[15px] leading-snug text-muted-foreground">
                  <Icon
                    name="hugeicons:arrow-right-01"
                    class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                  />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
