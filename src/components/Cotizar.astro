---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";

interface Props {
  servicioPreseleccionado?: string;
}
const { servicioPreseleccionado } = Astro.props;

const servicios = [
  "Hidrojet y Destapes",
  "Gasfitería",
  "Cerrajería y Estructuras",
  "Obras Civiles",
  "Limpieza de campanas",
  "Pinturas corporativas",
  "Emergencia 24/7",
  "Otro / No estoy seguro",
];
---

<section id="cotizar" class="relative overflow-hidden bg-ink text-background py-20 lg:py-28">
  <div class="tech-grid pointer-events-none absolute inset-0 opacity-50"></div>
  <div class="container-x relative">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <p class="eyebrow flex items-center gap-2.5 !text-primary">
          <span class="h-px w-8 bg-primary"></span>
          Contacto directo
        </p>
        <h2 class="mt-6 font-display text-4xl font-extrabold uppercase tracking-tight sm:text-5xl">
          ¿Conversemos sobre tu infraestructura?
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-background/65">
          Cuéntanos qué necesitas y te contactamos con una cotización clara.
          Atención para empresas, condominios y hogares en toda la RM.
        </p>

        <div class="mt-10 space-y-6">
          <a href="tel:+56940170148" class="block">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-background/50">Teléfonos</p>
            <p class="mt-1 text-xl font-bold">+56 9 4017 0148 · +56 2 2322 1685</p>
          </a>
          <div class="h-px w-24 bg-white/15"></div>
          <div>
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-background/50">Correo</p>
            <p class="mt-1 text-lg font-bold">seguimientomasdechile@gmail.com</p>
          </div>
          <div>
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-background/50">Oficina central</p>
            <p class="mt-1 text-lg font-bold">Santa Elena 2362, Of. 301 · San Joaquín</p>
          </div>
        </div>
      </div>

      <form
        id="cotizar-form"
        data-reveal
        data-wa={site.whatsapp}
        class="rounded-lg bg-surface text-foreground p-8 shadow-soft"
      >
        <div class="grid gap-4">
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="nombre">Nombre</label>
            <input
              id="nombre"
              required
              type="text"
              placeholder="Tu nombre"
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="fono">Teléfono</label>
            <input
              id="fono"
              required
              type="tel"
              placeholder="+56 9 ..."
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="servicio">Servicio</label>
            <select
              id="servicio"
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            >
              {
                servicios.map((s) => (
                  <option selected={s === servicioPreseleccionado}>{s}</option>
                ))
              }
            </select>
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="mensaje">Cuéntanos qué necesitas</label>
            <textarea
              id="mensaje"
              rows="3"
              placeholder="Describe el problema..."
              class="w-full resize-none border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            ></textarea>
          </div>
          <button
            type="submit"
            class="mt-2 inline-flex items-center justify-center gap-2 rounded-md bg-primary px-6 py-3.5 text-sm font-bold uppercase tracking-wide text-accent-foreground transition hover:bg-accent-strong"
          >
            <Icon name="hugeicons:whatsapp" class="h-4 w-4" />
            Enviar por WhatsApp
          </button>
          <p id="form-ok" class="hidden text-center text-sm font-semibold text-success">
            Abriendo WhatsApp...
          </p>
          <p class="text-center text-xs text-muted-foreground">
            Respondemos en menos de 30 minutos
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("cotizar-form");
    if (!form) return;
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const wa = form.getAttribute("data-wa");
      const val = (id) => (document.getElementById(id)?.value || "").trim();
      const nombre = val("nombre");
      const fono = val("fono");
      const servicio = val("servicio");
      const mensaje = val("mensaje");
      const lineas = [
        "Hola! Quiero cotizar un servicio.",
        nombre && `Nombre: ${nombre}`,
        servicio && `Servicio: ${servicio}`,
        fono && `Telefono: ${fono}`,
        mensaje && `Detalle: ${mensaje}`,
      ].filter(Boolean);
      const url =
        "https://wa.me/" + wa + "?text=" + encodeURIComponent(lineas.join("\n"));
      const ok = document.getElementById("form-ok");
      if (ok) ok.classList.remove("hidden");
      window.open(url, "_blank", "noopener");
    });
  })();
</script>
