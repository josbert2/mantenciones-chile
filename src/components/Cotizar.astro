---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";

interface Props {
  servicioPreseleccionado?: string;
}
const { servicioPreseleccionado } = Astro.props;

const servicios = [
  "Gasfiteria",
  "Electricidad",
  "Climatizacion",
  "Emergencia 24/7",
];
---

<section id="cotizar" class="bg-primary text-primary-foreground py-20 lg:py-28">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div data-reveal>
        <h2 class="text-5xl font-display tracking-tight">
          Pide tu visita hoy
        </h2>
        <p class="mt-6 text-lg text-primary-foreground/80 max-w-md leading-relaxed">
          Dejanos tus datos y te contactamos en minutos con cotización clara.
        </p>

        <div class="mt-10 space-y-6">
          <a href="tel:+56912345678" class="block">
            <p class="text-sm text-primary-foreground/60 font-semibold">Llamanos</p>
            <p class="text-xl font-bold mt-1">+56 9 1234 5678</p>
          </a>
          <div class="w-24 h-px bg-white/20"></div>
          <div>
            <p class="text-sm text-primary-foreground/60 font-semibold">Email</p>
            <p class="text-lg font-bold mt-1">hola@masdechile.cl</p>
          </div>
        </div>
      </div>

      <form
        id="cotizar-form"
        data-reveal
        data-wa={site.whatsapp}
        class="bg-white text-foreground p-8"
      >
        <div class="grid gap-4">
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="nombre">Nombre</label>
            <input
              id="nombre"
              required
              type="text"
              placeholder="Tu nombre"
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="fono">Teléfono</label>
            <input
              id="fono"
              required
              type="tel"
              placeholder="+56 9 ..."
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="servicio">Servicio</label>
            <select
              id="servicio"
              class="w-full border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            >
              {
                servicios.map((s) => (
                  <option selected={s === servicioPreseleccionado}>{s}</option>
                ))
              }
            </select>
          </div>
          <div>
            <label class="block text-sm font-bold text-foreground mb-2" for="mensaje">Cuéntanos qué necesitas</label>
            <textarea
              id="mensaje"
              rows="3"
              placeholder="Describe el problema..."
              class="w-full resize-none border border-border bg-background px-4 py-2.5 text-sm outline-none focus:border-primary"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-primary text-white px-6 py-3 text-sm font-bold transition hover:bg-primary/90 mt-2"
          >
            Enviar por WhatsApp
          </button>
          <p id="form-ok" class="hidden text-center text-sm font-semibold text-success">
            Abriendo WhatsApp...
          </p>
          <p class="text-center text-xs text-muted-foreground">
            Respondemos en menos de 30 minutos
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("cotizar-form");
    if (!form) return;
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const wa = form.getAttribute("data-wa");
      const val = (id) => (document.getElementById(id)?.value || "").trim();
      const nombre = val("nombre");
      const fono = val("fono");
      const servicio = val("servicio");
      const mensaje = val("mensaje");
      const lineas = [
        "Hola! Quiero cotizar un servicio.",
        nombre && `Nombre: ${nombre}`,
        servicio && `Servicio: ${servicio}`,
        fono && `Telefono: ${fono}`,
        mensaje && `Detalle: ${mensaje}`,
      ].filter(Boolean);
      const url =
        "https://wa.me/" + wa + "?text=" + encodeURIComponent(lineas.join("\n"));
      const ok = document.getElementById("form-ok");
      if (ok) ok.classList.remove("hidden");
      window.open(url, "_blank", "noopener");
    });
  })();
</script>
