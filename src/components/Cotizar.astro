---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";
import { servicios } from "../data/servicios";

interface Props {
  servicioPreseleccionado?: string;
}
const { servicioPreseleccionado } = Astro.props;

const opciones = [
  ...servicios.map((s) => s.titulo),
  "Otro / No estoy seguro",
];

const contacto = [
  {
    icon: "hugeicons:call-02",
    label: "Teléfonos",
    valor: `${site.phoneDisplay} · ${site.phoneAltDisplay}`,
    href: `tel:${site.phone}`,
  },
  {
    icon: "hugeicons:mail-01",
    label: "Correo",
    valor: site.email,
    href: `mailto:${site.email}`,
  },
  {
    icon: "hugeicons:location-01",
    label: "Oficina central",
    valor: `${site.address.street} · ${site.address.city}`,
    href: null,
  },
];
---

<section id="cotizar" class="py-24 lg:py-32">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-16">
      <!-- Info -->
      <div data-reveal>
        <div class="flex items-center gap-1 font-mono text-sm text-primary">
          <span>//</span>
          <span>Contacto</span>
        </div>

        <h2
          class="mt-3 max-w-md text-3xl font-semibold leading-[1.15] tracking-[-0.02em] text-foreground sm:text-4xl"
        >
          ¿Conversemos sobre tu <em class="font-serif font-normal italic"
            >infraestructura</em
          >?
        </h2>

        <p class="mt-5 max-w-md leading-relaxed text-muted-foreground">
          Cuéntanos qué necesitas y te contactamos con una cotización clara.
          Atención para empresas, condominios y hogares en toda la Región
          Metropolitana.
        </p>

        {/* Atajo directo: para quien no quiere llenar el formulario */}
        <a
          href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent("Hola Más de Chile! Quiero hacer una consulta.")}`}
          target="_blank"
          rel="noopener"
          data-track="whatsapp"
          class="mt-7 inline-flex items-center gap-3 rounded-full bg-[#25D366] py-3 pl-4 pr-6 font-semibold text-white shadow-sm transition-transform hover:-translate-y-0.5"
        >
          <span class="grid h-8 w-8 place-items-center rounded-full bg-white/20">
            <Icon name="hugeicons:whatsapp" class="h-5 w-5" />
          </span>
          Escríbenos directo por WhatsApp
        </a>
        <p class="mt-2 text-sm text-muted-foreground">
          ¿Sin ganas de llenar el formulario? Escríbenos y listo.
        </p>

        <ul class="mt-10 space-y-5">
          {
            contacto.map((c) => (
              <li class="flex items-start gap-4">
                <span class="grid h-11 w-11 shrink-0 place-items-center rounded-lg bg-primary/10 text-primary">
                  <Icon name={c.icon} class="h-5 w-5" />
                </span>
                <div>
                  <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-muted-foreground">
                    {c.label}
                  </p>
                  {c.href ? (
                    <a
                      href={c.href}
                      class="mt-0.5 block font-bold text-foreground transition-colors hover:text-primary"
                    >
                      {c.valor}
                    </a>
                  ) : (
                    <p class="mt-0.5 font-bold text-foreground">{c.valor}</p>
                  )}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Formulario -->
      <form
        id="cotizar-form"
        data-reveal
        data-wa={site.whatsapp}
        class="rounded-2xl border border-border bg-surface p-7 shadow-soft sm:p-9"
      >
        <div class="grid gap-5">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label
                class="mb-2 block text-sm font-semibold text-foreground"
                for="nombre">Nombre</label
              >
              <input
                id="nombre"
                required
                type="text"
                placeholder="Tu nombre"
                class="w-full rounded-lg border border-border bg-background px-4 py-3 text-sm outline-none transition-colors focus:border-primary"
              />
            </div>
            <div>
              <label
                class="mb-2 block text-sm font-semibold text-foreground"
                for="fono">Teléfono</label
              >
              <input
                id="fono"
                required
                type="tel"
                placeholder="+56 9 ..."
                class="w-full rounded-lg border border-border bg-background px-4 py-3 text-sm outline-none transition-colors focus:border-primary"
              />
            </div>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-semibold text-foreground"
              for="tipo">¿Quién eres?</label
            >
            <select
              id="tipo"
              class="w-full rounded-lg border border-border bg-background px-4 py-3 text-sm outline-none transition-colors focus:border-primary"
            >
              <option>Empresa / Condominio</option>
              <option>Particular</option>
            </select>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-semibold text-foreground"
              for="servicio">Servicio</label
            >
            <select
              id="servicio"
              class="w-full rounded-lg border border-border bg-background px-4 py-3 text-sm outline-none transition-colors focus:border-primary"
            >
              {
                opciones.map((s) => (
                  <option selected={s === servicioPreseleccionado}>{s}</option>
                ))
              }
            </select>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-semibold text-foreground"
              for="mensaje">Cuéntanos qué necesitas</label
            >
            <textarea
              id="mensaje"
              rows="4"
              placeholder="Describe el trabajo o la emergencia..."
              class="w-full resize-none rounded-lg border border-border bg-background px-4 py-3 text-sm outline-none transition-colors focus:border-primary"
            ></textarea>
          </div>

          {/* Honeypot anti-spam: invisible para humanos, los bots lo llenan */}
          <input
            type="text"
            name="website"
            id="website"
            tabindex="-1"
            autocomplete="off"
            class="absolute left-[-9999px] h-0 w-0 opacity-0"
            aria-hidden="true"
          />

          <button
            id="cotizar-btn"
            type="submit"
            class="group inline-flex items-center justify-center gap-2.5 rounded-full bg-primary py-3.5 pl-6 pr-3 text-sm font-bold text-white transition-transform hover:-translate-y-0.5 disabled:opacity-60"
          >
            <span data-btn-label>Enviar solicitud</span>
            <span
              class="grid h-6 w-6 place-items-center rounded-full bg-white text-primary transition-transform group-hover:translate-x-0.5"
            >
              <Icon name="hugeicons:arrow-right-01" class="h-3.5 w-3.5" />
            </span>
          </button>

          <p
            id="form-ok"
            class="hidden rounded-lg bg-success/10 px-4 py-3 text-center text-sm font-semibold text-success"
          >
            ¡Listo! Recibimos tu solicitud, te contactamos a la brevedad.
          </p>
          <p
            id="form-err"
            class="hidden rounded-lg bg-danger/10 px-4 py-3 text-center text-sm font-semibold text-danger"
          >
            No pudimos enviar. Escríbenos por WhatsApp y te atendemos igual.
          </p>
          <p class="text-center text-xs text-muted-foreground">
            Respondemos en menos de 30 minutos en horario hábil.
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById("cotizar-form");
    if (!form) return;
    const btn = document.getElementById("cotizar-btn");
    const label = form.querySelector("[data-btn-label]");
    const ok = document.getElementById("form-ok");
    const err = document.getElementById("form-err");
    const val = (id) => (document.getElementById(id)?.value || "").trim();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      ok.classList.add("hidden");
      err.classList.add("hidden");
      btn.disabled = true;
      const txt = label.textContent;
      label.textContent = "Enviando...";

      const payload = {
        nombre: val("nombre"),
        fono: val("fono"),
        tipo: val("tipo"),
        servicio: val("servicio"),
        mensaje: val("mensaje"),
        website: val("website"), // honeypot
      };

      try {
        const r = await fetch("/api/cotizar", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!r.ok) throw new Error("http " + r.status);
        // Conversión: envío de formulario de cotización
        if (window.track) window.track("cotizacion", { servicio: payload.servicio });
        form.reset();
        ok.classList.remove("hidden");
      } catch (_) {
        err.classList.remove("hidden");
      } finally {
        btn.disabled = false;
        label.textContent = txt;
      }
    });
  })();
</script>
