---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import HeroRefit from "../components/HeroRefit.astro";
import Services from "../components/Services.astro";
import CasosExito from "../components/CasosExito.astro";
import Equipo from "../components/Equipo.astro";
import WhyUs from "../components/WhyUs.astro";
import Process from "../components/Process.astro";
import Testimonials from "../components/Testimonials.astro";
import Pricing from "../components/Pricing.astro";
import Faq from "../components/Faq.astro";
import Cotizar from "../components/Cotizar.astro";
import Footer from "../components/Footer.astro";
import ChatbotWhatsapp from "../components/ChatbotWhatsapp.astro";
import { localBusiness, websiteSchema } from "../lib/schema";

const jsonLd = [localBusiness(), websiteSchema()];
---

<Layout
  title="Más de Chile — Servicios técnicos especializados RM"
  description="Hidrojet, gasfitería, cerrajería, obras civiles, emergencias 24/7 y más. Servicios técnicos profesionales para empresas, condominios y hogares en la Región Metropolitana."
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <Hero />
    <Services />
    <CasosExito />
    <Equipo />
    <WhyUs />
    <Process />
    <Testimonials />
    <HeroRefit />
    <Pricing />
    <Faq />
    <Cotizar />
  </main>
  <Footer />

  <ChatbotWhatsapp />
</Layout>
