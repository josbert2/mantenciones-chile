---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Faq from "../../components/Faq.astro";
import Cotizar from "../../components/Cotizar.astro";
import TrabajosDeServicio from "../../components/TrabajosDeServicio.astro";
import Footer from "../../components/Footer.astro";
import { Icon } from "astro-icon/components";
import { servicios, type Servicio } from "../../data/servicios";
import { comunas } from "../../data/comunas";
import { serviceSchema, breadcrumb, localBusiness } from "../../lib/schema";
import { site } from "../../data/site";

export function getStaticPaths() {
  return servicios.map((s) => ({ params: { slug: s.slug }, props: { s } }));
}

interface Props {
  s: Servicio;
}
const { s } = Astro.props;

const cdn = (nombre: string, ancho: 800 | 1600 = 800) =>
  `/trabajos/${nombre}-${ancho}.webp`;

const otros = servicios.filter((x) => x.slug !== s.slug).slice(0, 3);

const jsonLd = [
  serviceSchema(s),
  breadcrumb([
    { name: "Inicio", path: "/" },
    { name: "Servicios", path: "/servicios" },
    { name: s.nombre, path: `/servicios/${s.slug}` },
  ]),
  localBusiness(),
];
---

<Layout
  title={s.seoTitle}
  description={s.seoDescription}
  canonical={`/servicios/${s.slug}`}
  image={`/og/${s.slug}.png`}
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <!-- Hero: foto a pantalla completa -->
    <section class="relative overflow-hidden">
      <img
        src={cdn(s.imagen, 1600)}
        alt=""
        aria-hidden="true"
        width="1600"
        height="1600"
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/70 to-black/35"
      >
      </div>

      <div class="container-x relative py-16 lg:py-24">
        <!-- Migas -->
        <nav aria-label="Migas de pan" class="text-sm text-white/55">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li><a href="/" class="transition-colors hover:text-white">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li>
              <a href="/servicios" class="transition-colors hover:text-white"
                >Servicios</a
              >
            </li>
            <li aria-hidden="true">/</li>
            <li class="font-semibold text-primary" aria-current="page">
              {s.nombre}
            </li>
          </ol>
        </nav>

        <div class="mt-10 grid items-end gap-10 lg:grid-cols-[1.1fr_360px] lg:gap-16">
          <div>
            <div
              class="flex items-center gap-2 font-mono text-sm text-primary"
              data-reveal
            >
              <Icon name={s.icon} class="h-4 w-4" />
              <span>// Servicio</span>
            </div>

            <h1
              class="mt-4 text-4xl font-semibold leading-[1.08] tracking-[-0.02em] text-white sm:text-5xl lg:text-[3.6rem]"
              data-reveal
            >
              {s.titulo}
            </h1>

            <p
              class="mt-6 max-w-xl text-lg leading-relaxed text-white/70"
              data-reveal
            >
              {s.intro}
            </p>

            <div class="mt-9 flex flex-wrap items-center gap-4" data-reveal>
              <a
                href="#cotizar"
                class="group inline-flex items-center gap-2.5 rounded-full bg-primary py-3 pl-6 pr-3 text-sm font-bold text-white transition-transform hover:-translate-y-0.5"
              >
                Solicitar cotización
                <span
                  class="grid h-6 w-6 place-items-center rounded-full bg-white text-primary transition-transform group-hover:translate-x-0.5"
                >
                  <Icon name="hugeicons:arrow-right-01" class="h-3.5 w-3.5" />
                </span>
              </a>
              <a
                href={`tel:${site.phone}`}
                data-track="llamada"
                class="inline-flex items-center gap-2.5 text-sm font-semibold text-white transition-colors hover:text-primary"
              >
                <span class="relative grid h-9 w-9 place-items-center rounded-full bg-white/15 backdrop-blur-sm">
                  <Icon name="hugeicons:call-02" class="h-4 w-4" />
                  <span class="absolute inset-0 animate-ping rounded-full bg-white/20"
                  ></span>
                </span>
                Emergencia 24/7 · {site.phoneDisplay}
              </a>
            </div>
          </div>

          <!-- Tarjeta blanca: qué incluye (resumen) -->
          <div class="rounded-2xl bg-white p-7 shadow-soft" data-reveal>
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.16em] text-primary">
              Incluye {s.incluye.length} prestaciones
            </p>
            <ul class="mt-4 space-y-3">
              {
                s.incluye.slice(0, 4).map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-foreground">
                    <Icon
                      name="hugeicons:tick-02"
                      class="mt-0.5 h-4 w-4 shrink-0 text-primary"
                    />
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Qué incluye (completo) -->
    <section class="py-20 lg:py-28">
      <div class="container-x">
        <div class="max-w-2xl">
          <div class="flex items-center gap-1 font-mono text-sm text-primary" data-reveal>
            <span>//</span>
            <span>Alcance</span>
          </div>
          <h2
            class="mt-3 text-3xl font-semibold leading-[1.15] tracking-[-0.02em] text-foreground sm:text-4xl"
            data-reveal
          >
            Qué incluye nuestro servicio de <em
              class="font-serif font-normal italic">{s.nombre.toLowerCase()}</em
            >
          </h2>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            s.incluye.map((item) => (
              <div
                class="flex items-start gap-3 rounded-xl border border-border bg-surface p-5"
                data-reveal
              >
                <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-primary/10 text-primary">
                  <Icon name="hugeicons:tick-02" class="h-4 w-4" />
                </span>
                <span class="text-[15px] font-medium leading-snug text-foreground">
                  {item}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Cobertura por comuna -->
    <section class="border-y border-border bg-surface py-16">
      <div class="container-x">
        <h2
          class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl"
          data-reveal
        >
          {s.nombre} por comuna
        </h2>
        <p class="mt-3 max-w-2xl text-muted-foreground" data-reveal>
          Atendemos en toda la Región Metropolitana, con despacho de cuadrilla desde nuestra base en San Joaquín:
        </p>
        <div class="mt-6 flex flex-wrap gap-2" data-reveal>
          {
            comunas.map((c) => (
              <span class="rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-muted-foreground">
                {c.nombre}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <Faq
      faqs={s.faqs}
      eyebrow={`Preguntas sobre ${s.nombre.toLowerCase()}`}
      titulo={`Dudas frecuentes de ${s.nombre.toLowerCase()}`}
    />

    <!-- Otros servicios -->
    <section class="py-16 lg:py-20">
      <div class="container-x">
        <h2
          class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl"
          data-reveal
        >
          Otros servicios
        </h2>

        <div class="mt-8 grid gap-6 sm:grid-cols-3">
          {
            otros.map((o) => (
              <a
                href={`/servicios/${o.slug}`}
                class="group flex flex-col gap-4"
                data-reveal
              >
                <figure class="aspect-[381/280] overflow-hidden rounded-xl bg-muted">
                  <img
                    src={cdn(o.imagen, 800)}
                    alt={o.titulo}
                    width="381"
                    height="280"
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                </figure>
                <div>
                  <h3 class="text-lg font-semibold text-foreground transition-colors group-hover:text-primary">
                    {o.titulo}
                  </h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
                    {o.resumen}
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <TrabajosDeServicio servicio={s.slug} titulo={s.titulo} />
    <Cotizar servicioPreseleccionado={s.titulo} />
  </main>
  <Footer />
</Layout>
