---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Faq from "../../components/Faq.astro";
import Cotizar from "../../components/Cotizar.astro";
import Footer from "../../components/Footer.astro";
import { Icon } from "astro-icon/components";
import { servicios, type Servicio } from "../../data/servicios";
import { comunas } from "../../data/comunas";
import { serviceSchema, breadcrumb, localBusiness } from "../../lib/schema";

export function getStaticPaths() {
  return servicios.map((s) => ({ params: { slug: s.slug }, props: { s } }));
}

interface Props {
  s: Servicio;
}
const { s } = Astro.props;

const cdn = (id: string) =>
  `https://framerusercontent.com/images/${id}.png?scale-down-to=1024&width=2048&height=2048`;
const otros = servicios.filter((x) => x.slug !== s.slug);

const jsonLd = [
  serviceSchema(s),
  breadcrumb([
    { name: "Inicio", path: "/" },
    { name: "Servicios", path: "/servicios" },
    { name: s.nombre, path: `/servicios/${s.slug}` },
  ]),
  localBusiness(),
];
---

<Layout
  title={s.seoTitle}
  description={s.seoDescription}
  canonical={`/servicios/${s.slug}`}
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <!-- Hero del servicio -->
    <section class="pt-10 lg:pt-14">
      <div class="container-x">
        <nav aria-label="Migas de pan" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li><a href="/" class="hover:text-accent-strong">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li>
              <a href="/servicios" class="hover:text-accent-strong">Servicios</a>
            </li>
            <li aria-hidden="true">/</li>
            <li class="font-semibold text-primary" aria-current="page">
              {s.nombre}
            </li>
          </ol>
        </nav>

        <div class="mt-8 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-xs font-semibold text-primary"
            >
              <Icon name={s.icon} class="h-4 w-4 text-accent-strong" />
              Servicio de {s.nombre.toLowerCase()}
            </span>
            <h1
              class="mt-5 font-display text-4xl uppercase leading-[0.95] tracking-tight text-foreground sm:text-5xl"
            >
              {s.nombre}
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground">
              {s.intro}
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="/#cotizar"
                class="rounded-full bg-accent px-6 py-3.5 text-xs font-bold uppercase tracking-wide text-accent-foreground transition-transform hover:-translate-y-0.5"
                >Pedir cotizacion</a
              >
              <a
                href="tel:+56912345678"
                class="rounded-full border border-border bg-surface px-6 py-3.5 text-xs font-bold uppercase tracking-wide text-primary transition-colors hover:bg-muted"
                >Llamar ahora</a
              >
            </div>
          </div>

          <div class="relative overflow-hidden rounded-3xl border border-border shadow-soft">
            <img
              src={cdn(s.imagen)}
              alt={`Servicio de ${s.nombre} — Mantenciones Chile`}
              width="1024"
              height="1024"
              class="aspect-[4/3] w-full object-cover"
              loading="eager"
            />
            <span class="grain-layer" aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </section>

    <!-- Que incluye -->
    <section class="py-20 lg:py-24">
      <div class="container-x">
        <h2
          class="text-3xl font-display uppercase tracking-tight text-foreground sm:text-4xl"
        >
          Que incluye nuestro servicio de {s.nombre.toLowerCase()}
        </h2>
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            s.incluye.map((item) => (
              <div class="flex items-start gap-3 rounded-2xl border border-border bg-surface p-5">
                <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-success/10 text-success">
                  <Icon name="hugeicons:wrench-01" class="h-4 w-4" />
                </span>
                <span class="text-[15px] font-medium text-foreground">{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Cobertura por comuna (SEO local) -->
    <section class="py-16">
      <div class="container-x">
        <h2
          class="text-2xl font-display uppercase tracking-tight text-foreground sm:text-3xl"
        >
          {s.nombre} por comuna
        </h2>
        <p class="mt-3 max-w-2xl text-muted-foreground">
          Atendemos en toda la Region Metropolitana. Elige tu comuna:
        </p>
        <div class="mt-6 flex flex-wrap gap-2.5">
          {
            comunas.map((c) => (
              <a
                href={`/servicios/${s.slug}/${c.slug}`}
                class="rounded-full border border-border bg-surface px-4 py-2 text-sm font-medium text-primary transition-colors hover:bg-muted"
              >
                {c.nombre}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <Faq
      faqs={s.faqs}
      eyebrow={`Preguntas sobre ${s.nombre.toLowerCase()}`}
      titulo={`Dudas frecuentes de ${s.nombre.toLowerCase()}`}
    />

    <!-- Otros servicios -->
    <section class="py-16">
      <div class="container-x">
        <h2
          class="text-2xl font-display uppercase tracking-tight text-foreground sm:text-3xl"
        >
          Otros servicios
        </h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-3">
          {
            otros.map((o) => (
              <a
                href={`/servicios/${o.slug}`}
                class="group rounded-3xl border border-border bg-surface p-6 transition-all hover:-translate-y-1 hover:shadow-soft"
              >
                <span class="grid h-11 w-11 place-items-center rounded-2xl bg-primary/5 text-primary transition-colors group-hover:bg-accent group-hover:text-accent-foreground">
                  <Icon name={o.icon} class="h-5 w-5" />
                </span>
                <h3 class="mt-4 font-bold text-primary">{o.titulo}</h3>
                <p class="mt-1.5 text-sm text-muted-foreground">{o.resumen}</p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <Cotizar />
  </main>
  <Footer />

  <a
    href="https://wa.me/56912345678?text=Hola!%20Quiero%20mas%20informacion%20sobre%20sus%20servicios%20de%20mantencion."
    target="_blank"
    rel="noopener"
    aria-label="Escribir por WhatsApp"
    class="fixed bottom-5 right-5 z-50 grid h-14 w-14 place-items-center rounded-full bg-success text-white shadow-soft transition-transform hover:-translate-y-1"
  >
    <Icon name="hugeicons:whatsapp" class="h-7 w-7" />
  </a>
</Layout>
