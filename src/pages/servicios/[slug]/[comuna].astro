---
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Faq from "../../../components/Faq.astro";
import Cotizar from "../../../components/Cotizar.astro";
import Footer from "../../../components/Footer.astro";
import { Icon } from "astro-icon/components";
import { servicios, type Servicio } from "../../../data/servicios";
import { comunas, type Comuna } from "../../../data/comunas";
import { localServiceSchema, breadcrumb, localBusiness } from "../../../lib/schema";

export function getStaticPaths() {
  return servicios.flatMap((s) =>
    comunas.map((c) => ({
      params: { slug: s.slug, comuna: c.slug },
      props: { s, c },
    })),
  );
}

interface Props {
  s: Servicio;
  c: Comuna;
}
const { s, c } = Astro.props;

const cdn = (id: string) =>
  `https://framerusercontent.com/images/${id}.png?scale-down-to=512&width=2048&height=2048`;
const otrasComunas = comunas.filter((x) => x.slug !== c.slug).slice(0, 8);

const jsonLd = [
  localServiceSchema(s, c.nombre),
  breadcrumb([
    { name: "Inicio", path: "/" },
    { name: "Servicios", path: "/servicios" },
    { name: s.nombre, path: `/servicios/${s.slug}` },
    { name: c.nombre, path: `/servicios/${s.slug}/${c.slug}` },
  ]),
  localBusiness(),
];
---

<Layout
  title={`${s.nombre} en ${c.nombre} | Mantenciones Chile`}
  description={`${s.nombre} a domicilio en ${c.nombre}. Tecnicos certificados, cotizacion clara y garantia de 90 dias. Atencion en 24 hrs.`}
  canonical={`/servicios/${s.slug}/${c.slug}`}
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <section class="pt-10 lg:pt-14">
      <div class="container-x">
        <nav aria-label="Migas de pan" class="text-sm text-muted-foreground">
          <ol class="flex flex-wrap items-center gap-1.5">
            <li><a href="/" class="hover:text-accent-strong">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li>
              <a href="/servicios" class="hover:text-accent-strong">Servicios</a>
            </li>
            <li aria-hidden="true">/</li>
            <li>
              <a href={`/servicios/${s.slug}`} class="hover:text-accent-strong"
                >{s.nombre}</a
              >
            </li>
            <li aria-hidden="true">/</li>
            <li class="font-semibold text-primary" aria-current="page">
              {c.nombre}
            </li>
          </ol>
        </nav>

        <div class="mt-8 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3.5 py-1.5 text-xs font-semibold text-primary"
            >
              <Icon name="hugeicons:location-01" class="h-4 w-4 text-accent-strong" />
              {c.nombre}, Region Metropolitana
            </span>
            <h1
              class="mt-5 font-display text-4xl uppercase leading-[0.95] tracking-tight text-foreground sm:text-5xl"
            >
              {s.nombre} en {c.nombre}
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground">
              Servicio de {s.nombre.toLowerCase()} a domicilio en {c.nombre}. Llegamos
              rapido a tu direccion con tecnicos certificados, cotizacion clara y
              garantia de 90 dias. {s.intro}
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href="#cotizar"
                class="rounded-full bg-accent px-6 py-3.5 text-xs font-bold uppercase tracking-wide text-accent-foreground transition-transform hover:-translate-y-0.5"
                >Pedir cotizacion</a
              >
              <a
                href="tel:+56912345678"
                class="rounded-full border border-border bg-surface px-6 py-3.5 text-xs font-bold uppercase tracking-wide text-primary transition-colors hover:bg-muted"
                >Llamar ahora</a
              >
            </div>
          </div>

          <div class="relative overflow-hidden rounded-3xl border border-border shadow-soft">
            <img
              src={cdn(s.imagen)}
              alt={`${s.nombre} en ${c.nombre} — Mantenciones Chile`}
              width="512"
              height="512"
              class="aspect-[4/3] w-full object-cover"
              loading="eager"
            />
            <span class="grain-layer" aria-hidden="true"></span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-24">
      <div class="container-x">
        <h2
          class="text-3xl font-display uppercase tracking-tight text-foreground sm:text-4xl"
        >
          {s.nombre} a domicilio en {c.nombre}
        </h2>
        <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
          Esto es lo que resolvemos en {c.nombre} y alrededores:
        </p>
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {
            s.incluye.map((item) => (
              <div class="flex items-start gap-3 rounded-2xl border border-border bg-surface p-5">
                <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-success/10 text-success">
                  <Icon name="hugeicons:wrench-01" class="h-4 w-4" />
                </span>
                <span class="text-[15px] font-medium text-foreground">{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <Faq
      faqs={s.faqs}
      eyebrow={`${s.nombre} en ${c.nombre}`}
      titulo={`Preguntas frecuentes en ${c.nombre}`}
    />

    <!-- Cobertura: otras comunas -->
    <section class="py-16">
      <div class="container-x">
        <h2
          class="text-2xl font-display uppercase tracking-tight text-foreground sm:text-3xl"
        >
          {s.nombre} en otras comunas
        </h2>
        <div class="mt-6 flex flex-wrap gap-2.5">
          {
            otrasComunas.map((o) => (
              <a
                href={`/servicios/${s.slug}/${o.slug}`}
                class="rounded-full border border-border bg-surface px-4 py-2 text-sm font-medium text-primary transition-colors hover:bg-muted"
              >
                {s.nombre} en {o.nombre}
              </a>
            ))
          }
          <a
            href={`/servicios/${s.slug}`}
            class="rounded-full bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground"
          >
            Ver todo el servicio
          </a>
        </div>
      </div>
    </section>

    <Cotizar servicioPreseleccionado={s.nombre} />
  </main>
  <Footer />

  <a
    href="https://wa.me/56912345678?text=Hola!%20Quiero%20cotizar%20un%20servicio%20de%20mantencion."
    target="_blank"
    rel="noopener"
    aria-label="Escribir por WhatsApp"
    class="fixed bottom-5 right-5 z-50 grid h-14 w-14 place-items-center rounded-full bg-success text-white shadow-soft transition-transform hover:-translate-y-1"
  >
    <Icon name="hugeicons:whatsapp" class="h-7 w-7" />
  </a>
</Layout>
