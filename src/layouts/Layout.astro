---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import Analytics from "../components/Analytics.astro";
import BotonWhatsapp from "../components/BotonWhatsapp.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, canonical, image, type, noindex, jsonLd } =
  Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/maschile.svg" />
    <link rel="apple-touch-icon" href="/maschile.svg" />
    <meta name="generator" content={Astro.generator} />

    <Seo
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <Analytics />
  </head>
  <body>
    <slot />
    <BotonWhatsapp />

    <script>
      // Smooth scroll simple y ligero
      function smoothScroll(target, duration = 400) {
        const start = window.scrollY;
        const end = target.getBoundingClientRect().top + start - 80;
        const distance = end - start;
        let startTime = null;

        function animation(currentTime) {
          if (startTime === null) startTime = currentTime;
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);

          // Easing: ease-out-cubic
          const easeProgress = 1 - Math.pow(1 - progress, 3);
          window.scrollTo(0, start + distance * easeProgress);

          if (progress < 1) {
            requestAnimationFrame(animation);
          }
        }

        requestAnimationFrame(animation);
      }

      document.querySelectorAll('a[href*="#"]').forEach((a) => {
        const url = new URL(a.href, location.href);
        if (url.pathname !== location.pathname || !url.hash) return;
        a.addEventListener("click", (e) => {
          const target = document.querySelector(url.hash);
          if (!target) return;
          e.preventDefault();
          history.replaceState(null, "", url.hash);
          smoothScroll(target);
        });
      });

      // Reveal on scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 },
      );
      document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => io.observe(el));

      // Nav movil
      const toggle = document.querySelector("[data-nav-toggle]");
      const menu = document.querySelector("[data-nav-menu]");
      toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
      });
      menu?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => menu.classList.add("hidden")),
      );

      // FAQ acordeon
      document.querySelectorAll("[data-faq]").forEach((item) => {
        const btn = item.querySelector("[data-faq-btn]");
        btn?.addEventListener("click", () => {
          const open = item.getAttribute("data-open") === "true";
          document
            .querySelectorAll("[data-faq]")
            .forEach((i) => i.setAttribute("data-open", "false"));
          item.setAttribute("data-open", open ? "false" : "true");
        });
      });
    </script>
  </body>
</html>
