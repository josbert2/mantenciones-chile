# Analítica y píxeles de conversión.
# Copiá este archivo a ".env" y completá los que uses.
# Solo se activa el tag cuyo ID esté presente. Requiere rebuild (npm run build).

# Google Analytics 4  -> Admin > Flujos de datos > ID de medición
PUBLIC_GA_ID=

# Google Ads  -> Herramientas > Conversiones. El ID de la cuenta (AW-...)
PUBLIC_ADS_ID=
# Etiqueta de la acción de conversión de Ads (la parte despues de la "/")
PUBLIC_ADS_LABEL=

# Meta / Facebook Pixel  -> Administrador de eventos > Origen de datos
PUBLIC_META_PIXEL_ID=

# Google Search Console -> Propiedad > Etiqueta HTML (solo el valor del content)
PUBLIC_GSC_VERIFICATION=

# Base CDN para servir videos (bucket R2). Sin esto, caen a /public local
PUBLIC_MEDIA_URL=
